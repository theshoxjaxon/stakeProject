# Copy to `.env` and fill in. Never commit `.env`.

# --- Database (SQLite only) ---
# DATABASE_URL=sqlite:///data/betting.db

# --- The Odds API ---
ODDS_API_KEY=

# --- Predictions ---
# Only matches with kickoff in the next N days (omit for no upper limit)
# PREDICTION_HORIZON_DAYS=7

# Minimum model edge vs de-margined fair implied (e.g. 0.05 = 5%)
# EDGE_THRESHOLD=0.05

# If true, main.py prints only value-bet lines (compact). Default: false = all upcoming matches with odds.
# SHOW_ONLY_VALUE_BETS=false

# Fractional Kelly multiplier applied to full Kelly stake
# KELLY_FRACTION=0.25

# Reference bankroll for display / sizing (optional)
# DEFAULT_BANKROLL=1000

# --- Feature engineering (Poisson λ multipliers) ---
# FEATURES_ENABLED=true
# FORM_WINDOW=10
# FORM_WEIGHT=0.08
# H2H_WEIGHT=0.06
# REST_SHORT_DAYS=3
# REST_FATIGUE_FACTOR=0.97
# MIDWEEK_FATIGUE_FACTOR=0.99

# --- Logging ---
# LOG_LEVEL=INFO
# LOG_DIR=data/logs
# LOG_FILE=betting_engine.log

# --- Sports (comma-separated keys) ---
# DEFAULT_SPORTS=soccer_epl,soccer_spain_la_liga,soccer_germany_bundesliga
